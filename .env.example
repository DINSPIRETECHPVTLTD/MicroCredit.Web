# Backend base URL - no "api/" in path (e.g. https://localhost:7119).
# Auth: {base}/auth/login, Users: {base}/Users/Org, {base}/api/users
#
# This is read at BUILD time. For dev deployment, set this to your dev API URL
# (e.g. https://your-dev-api.azurewebsites.net) before building, or use .env.development.
VITE_API_URL=https://localhost:7119
